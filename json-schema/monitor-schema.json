{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/bankruptcywatch/json-schema/monitor-schema.json",
  "title": "Monitor",
  "type": "object",
  "description": "A bankruptcy monitoring alert",
  "properties": {
    "monitorId": {
      "type": "string"
    },
    "monitorType": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "deleted"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastTriggeredAt": {
      "type": "string",
      "format": "date-time"
    },
    "alertCount": {
      "type": "integer"
    }
  }
}